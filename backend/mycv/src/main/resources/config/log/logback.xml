<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="springAppName" source="spring.application.name"/>
    <appender name="APP" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Append>true</Append>
        <File>C:/Users/Public/my_cv/log/MyCV.log</File>
        <encoder>
            <pattern>%d [${springAppName:-},%X{traceId:-},%X{spanId:-}] [%t] %-5p %c - %m%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>C:/Users/Public/my_cv/log/MyCV.%d{yyyy-MM-dd}.log</fileNamePattern>
        </rollingPolicy>
    </appender>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>utf8</charset>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP"/>
    </root>
    <logger name="LOGICAL" additivity="false" level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP"/>
    </logger>
    <logger name="FREE" additivity="false" level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP"/>
    </logger>
    <logger name="API" additivity="false" level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP"/>
    </logger>
    <logger name="EXCEPT" additivity="false" level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP"/>
    </logger>
    <logger name="MQ_ERROR" additivity="false" level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP"/>
    </logger>
    <logger name="org.quartz" additivity="false" level="ERROR">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP"/>
    </logger>
</configuration>
