<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.mycv.application.mapper.RoleMapper">
    <select id="findAll" resultType="com.project.mycv.domain.model.Role">
        SELECT id, role_name, description
        FROM roles
    </select>

    <select id="findById" resultType="com.project.mycv.domain.model.Role">
        SELECT id, role_name, description
        FROM roles
        WHERE id = #{id}
    </select>

    <select id="findByName" resultType="com.project.mycv.domain.model.Role">
        SELECT id, role_name, description
        FROM roles
        WHERE role_name = #{name}
    </select>
</mapper>