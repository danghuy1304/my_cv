# ============================================================
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên git
# ============================================================

# Database
DB_NAME=mycv
DB_USERNAME=postgres
DB_PASSWORD=your_strong_password

# JWT — bắt buộc, dùng chuỗi ngẫu nhiên dài ít nhất 32 ký tự
JWT_SECRET_KEY=your_very_long_and_secret_jwt_key_here
JWT_ACCESS_TOKEN=600
JWT_REFRESH_TOKEN=604800

# App URLs (khi deploy thật, đổi localhost thành domain thực)
CLIENT_URL=http://localhost:3000
COOKIE_DOMAIN=localhost
BASE_URL=http://localhost:8080

# Security
PASSWORD_SALT=your_password_salt_here
